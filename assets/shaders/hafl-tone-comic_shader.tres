code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool UseColor;
uniform bool BlackDot;
uniform float AspectRatio;
uniform float Dots;
uniform sampler2D screen_tex_frg_3 : hint_screen_texture;
uniform float min;
uniform float max;
uniform bool UseReshade;
uniform sampler2D screen_tex_frg_39 : hint_screen_texture;



void fragment() {
// BooleanParameter:64
	bool n_out64p0 = UseColor;


// BooleanParameter:62
	bool n_out62p0 = BlackDot;


// Input:5
	vec2 n_out5p0 = SCREEN_UV;


// FloatParameter:12
	float n_out12p0 = AspectRatio;


// FloatParameter:11
	float n_out11p0 = Dots;


// FloatOp:16
	float n_out16p0 = n_out12p0 * n_out11p0;


// VectorCompose:10
	float n_in10p2 = 0.00000;
	vec3 n_out10p0 = vec3(n_out16p0, n_out11p0, n_in10p2);


// VectorOp:17
	vec3 n_out17p0 = vec3(n_out5p0, 0.0) * n_out10p0;


// VectorFunc:18
	vec3 n_out18p0 = log(n_out17p0);


// Distance:19
	vec3 n_in19p1 = vec3(0.50000, 0.50000, 0.50000);
	float n_out19p0 = distance(n_out18p0, n_in19p1);


// Input:22
	vec2 n_out22p0 = SCREEN_UV;


// Input:2
	float n_out2p0 = 0.0;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(screen_tex_frg_3, n_out22p0);


	vec3 n_out70p0;
// ColorFunc:70
	{
		vec3 c = vec3(n_out3p0.xyz);
		float max1 = max(c.r, c.g);
		float max2 = max(max1, c.b);
		n_out70p0 = vec3(max2, max2, max2);
	}


// FloatParameter:27
	float n_out27p0 = min;


// FloatParameter:28
	float n_out28p0 = max;


// Clamp:30
	float n_out30p0 = clamp(n_out70p0.x, n_out27p0, n_out28p0);


// VectorOp:60
	vec3 n_in60p0 = vec3(1.00000, 1.00000, 1.00000);
	vec3 n_out60p0 = n_in60p0 - vec3(n_out30p0);


// Compare:65
	bool n_out65p0 = n_out19p0 > n_out60p0.x;


// Compare:20
	bool n_out20p0 = n_out19p0 < n_out30p0;


	float n_out61p0;
// Switch:61
	n_out61p0 = mix((n_out20p0 ? 1.0 : 0.0), (n_out65p0 ? 1.0 : 0.0), float(n_out62p0));


// BooleanParameter:74
	bool n_out74p0 = UseReshade;


// Input:71
	vec2 n_out71p0 = SCREEN_UV;


// Input:38
	float n_out38p0 = 0.0;


	vec4 n_out39p0;
// Texture2D:39
	n_out39p0 = texture(screen_tex_frg_39, n_out71p0);


	int n_out73p0;
// Expression:73
	n_out73p0 = 0;
	{
		vec3 c;
		c = int(n_out39p0.x);
		if ( abs(c.r - c.g) > .1 || abs(c.g - c.b) > .1 || abs(c.b - c.r) > .1 ){
			c.rgb = mix(vec3(0.0), c.rgb, 2); //Brightness
			c.rgb = mix(vec3(0.5), c.rgb, 1); // Contrast
			c.rgb = mix(vec3(dot(vec3(1.0), c.rgb)*0.33333), c.rgb, 2); //Saturation
		} else {
			c= vec3(1.0,1.0,1.0);
		}
		
		n_out73p0.rgb = c;
	}


	float n_out75p0;
// Switch:75
	n_out75p0 = mix(n_out39p0.x, float(n_out73p0), float(n_out74p0));


// VectorOp:54
	vec3 n_out54p0 = vec3(n_out61p0) * vec3(n_out75p0);


	float n_out63p0;
// Switch:63
	n_out63p0 = mix(n_out61p0, n_out54p0.x, float(n_out64p0));


// Output:0
	COLOR.rgb = vec3(n_out63p0);


}
