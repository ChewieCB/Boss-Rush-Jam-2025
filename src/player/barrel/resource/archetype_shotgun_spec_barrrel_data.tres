[resource]
script = ExtResource("3_1ouvy")
barrel_id = 7
barrel_name = "Archetype Shotgun Spec"
barrel_desc = "[b]Archetype Barrel - Shotgun Specialization[/b]
Change the innate nature of the gun. Ideally put this barrel at the first position.

Possible rolls:
[ul]
Combat shotgun: High firerate and magazine. Lower spread and projectile count.
Double-barrel shotgun: Limited magazine size and high spread, but huge damage.
Slug shotgun: Low spread and firerate. Very high damage but only one projectile.
[/ul]"
barrel_image = ExtResource("1_7kpif")
barrel_cost = 860
barrel_prefab = ExtResource("2_v2xxy")
is_archetype_barrel = true
