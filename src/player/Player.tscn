[node name="toInactive" type="Node" parent="StateChart/Root/Status/Burning/Active"]
script = ExtResource("10_g5bf6")
to = NodePath("../../Inactive")
event = &"remove_status_burning"
delay_in_seconds = "0.0"

[node name="BurningTimer" type="Timer" parent="StateChart/Root/Status/Burning"]

[node name="Poisoned" type="Node" parent="StateChart/Root/Status"]
script = ExtResource("7_1276k")
initial_state = NodePath("Inactive")

[node name="Inactive" type="Node" parent="StateChart/Root/Status/Poisoned"]
script = ExtResource("8_dkhcu")

[node name="toActive" type="Node" parent="StateChart/Root/Status/Poisoned/Inactive"]
script = ExtResource("10_g5bf6")
to = NodePath("../../Active")
event = &"add_status_poisoned"
guard = ExtResource("57_sguas")
delay_in_seconds = "0.0"

[node name="Active" type="Node" parent="StateChart/Root/Status/Poisoned"]
script = ExtResource("8_dkhcu")

[node name="toInactive" type="Node" parent="StateChart/Root/Status/Poisoned/Active"]
script = ExtResource("10_g5bf6")
to = NodePath("../../Inactive")
event = &"remove_status_poisoned"
delay_in_seconds = "0.0"

[node name="PoisonedTimer" type="Timer" parent="StateChart/Root/Status/Poisoned"]

[node name="Drunk" type="Node" parent="StateChart/Root/Status"]
script = ExtResource("7_1276k")
initial_state = NodePath("Inactive")

[node name="Inactive" type="Node" parent="StateChart/Root/Status/Drunk"]
script = ExtResource("8_dkhcu")

[node name="toActive" type="Node" parent="StateChart/Root/Status/Drunk/Inactive"]
script = ExtResource("10_g5bf6")
to = NodePath("../../Active")
event = &"add_status_drunk"
guard = ExtResource("57_sguas")
delay_in_seconds = "0.0"

[node name="Active" type="Node" parent="StateChart/Root/Status/Drunk"]
script = ExtResource("8_dkhcu")

[node name="toInactive" type="Node" parent="StateChart/Root/Status/Drunk/Active"]
script = ExtResource("10_g5bf6")
to = NodePath("../../Inactive")
event = &"remove_status_drunk"
delay_in_seconds = "0.0"

[node name="DrunkTimer" type="Timer" parent="StateChart/Root/Status/Drunk"]

[node name="OmniLight3D" type="OmniLight3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.2, 1, 0.2)
light_color = Color(0.78, 0.897333, 1, 1)

[connection signal="timeout" from="DashDuration" to="." method="_on_dash_duration_timeout"]
[connection signal="timeout" from="CoyoteTimer" to="." method="_on_coyote_timer_timeout"]
[connection signal="state_input" from="StateChart/Root/Movement/Grounded" to="." method="_on_grounded_state_input"]
[connection signal="state_physics_processing" from="StateChart/Root/Movement/Grounded" to="." method="_on_grounded_state_physics_processing"]
[connection signal="state_entered" from="StateChart/Root/Movement/Airborne" to="." method="_on_airborne_state_entered"]
[connection signal="state_input" from="StateChart/Root/Movement/Airborne" to="." method="_on_airborne_state_input"]
[connection signal="state_physics_processing" from="StateChart/Root/Movement/Airborne" to="." method="_on_airborne_state_physics_processing"]
[connection signal="state_entered" from="StateChart/Root/Health/Hurt" to="." method="_on_health_hurt_state_entered"]
[connection signal="state_entered" from="StateChart/Root/Health/Dead" to="." method="_on_health_dead_state_entered"]
[connection signal="state_physics_processing" from="StateChart/Root/Health/Dead" to="." method="_on_health_dead_state_physics_processing"]
[connection signal="state_entered" from="StateChart/Root/Status/Drunk/Active" to="." method="_on_status_drunk_active_state_entered"]
[connection signal="state_exited" from="StateChart/Root/Status/Drunk/Active" to="." method="_on_status_drunk_active_state_exited"]
