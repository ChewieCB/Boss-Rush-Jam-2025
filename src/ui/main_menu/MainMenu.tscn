bbcode_enabled = true
text = "You are a professional card cheat, caught red-handed in the towering mega-casino owned by the enigmatic [b][color=gold]Mr. Big[/color][/b]. 

Locked in a [b][color=red]plush lounge[/color][/b] high above the gaming floors, you are forced to enter a deadly game of chance — fighting against each of Mr. Big’s henchmen, all under the bleary-eyed gaze of an audience of gamblers placing bets on the bloodsport. 

Armed with a unique weapon whose [b][color=dark_turquoise]interchangeable barrels[/color][/b] spin random effects on each reload, you must acquire new barrels from every boss you defeat to build a weapon that can [b][color=lawn_green]change your odds[/color][/b]. 


[center][i]Gamble everything for your freedom.[/i][/center]"
fit_content = true

